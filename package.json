{
  "name": "holo",
  "private": true,
  "version": "0.1.5",
  "description": "Desktop Markdown editor with WYSIWYG experience and Git/GitHub workflow.",
  "author": {
    "name": "Romane Donnet",
    "email": "romane.donnet@outlook.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/romane-echino/holo.git"
  },
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && nodemon --watch electron --ext js,cjs,mjs --exec \"electron electron/main.js\"",
    "start": "electron electron/main.js",
    "build": "tsc -b && vite build",
    "dist": "npm run build && electron-builder --publish never -c.directories.output=release",
    "dist:win": "npm run build && electron-builder --win nsis portable --publish never -c.directories.output=release",
    "dist:mac": "npm run build && electron-builder --mac dmg zip --publish never -c.directories.output=release",
    "dist:linux": "npm run build && electron-builder --linux deb --publish never -c.directories.output=release",
    "lint": "eslint .",
    "preview": "vite preview",
    "release:patch": "bash ./scripts/release.sh patch",
    "release:minor": "bash ./scripts/release.sh minor",
    "release:major": "bash ./scripts/release.sh major",
    "release:version": "bash ./scripts/release.sh"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "marked": "^17.0.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "turndown": "^7.2.2",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "nodemon": "^3.1.14",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.holo.app",
    "productName": "Holo",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "buildResources": "public"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "win": {
      "icon": "public/logo-512.png",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "mac": {
      "icon": "public/logo-512.png",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "linux": {
      "icon": "public/logo-512.png",
      "maintainer": "Romane Donnet <romane.donnet@outlook.com>",
      "target": [
        "deb"
      ],
      "category": "Office"
    }
  }
}
